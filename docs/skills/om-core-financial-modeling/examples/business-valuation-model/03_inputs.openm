# Base scenario assumptions
rule Drivers::Driver.RevenueGrowth:Year.*:Scenario.Base = 0.10
rule Drivers::Driver.COGSRate:Year.*:Scenario.Base = 0.50
rule Drivers::Driver.SGARate:Year.*:Scenario.Base = 0.20
rule Drivers::Driver.ARDays:Year.*:Scenario.Base = 45
rule Drivers::Driver.InventoryDays:Year.*:Scenario.Base = 60
rule Drivers::Driver.APDays:Year.*:Scenario.Base = 30
rule Drivers::Driver.TaxRate:Year.*:Scenario.Base = 0.25
rule Drivers::Driver.InterestRate:Year.*:Scenario.Base = 0.05
rule Drivers::Driver.CapEx:Year.*:Scenario.Base = 500
rule Drivers::Driver.UsefulLife:Year.*:Scenario.Base = 10
rule Drivers::Driver.Debt:Year.*:Scenario.Base = 5000
rule Drivers::Driver.RiskFreeRate:Year.*:Scenario.Base = 0.03
rule Drivers::Driver.Beta:Year.*:Scenario.Base = 1.2
rule Drivers::Driver.MarketRiskPremium:Year.*:Scenario.Base = 0.05
rule Drivers::Driver.TargetDE:Year.*:Scenario.Base = 0.50
rule Drivers::Driver.TerminalGrowthRate:Year.*:Scenario.Base = 0.02
rule Drivers::Driver.BaseRevenue:Year.2026:Scenario.Base = 10000
rule Drivers::Driver.BaseNetFixedAssets:Year.2026:Scenario.Base = 5000
rule Drivers::Driver.BaseAccountsReceivable:Year.2026:Scenario.Base = 1200
rule Drivers::Driver.BaseInventory:Year.2026:Scenario.Base = 800
rule Drivers::Driver.BaseAccountsPayable:Year.2026:Scenario.Base = 400
rule Drivers::Driver.BaseEquity:Year.2026:Scenario.Base = 5000

# Upside scenario assumptions
