rule Drivers::Driver.BaseRevenue:Year.2026:Scenario.Upside = 12000
rule Drivers::Driver.BaseNetFixedAssets:Year.2026:Scenario.Upside = 6000
rule Drivers::Driver.BaseAccountsReceivable:Year.2026:Scenario.Upside = 1400
rule Drivers::Driver.BaseInventory:Year.2026:Scenario.Upside = 900
rule Drivers::Driver.BaseAccountsPayable:Year.2026:Scenario.Upside = 500
rule Drivers::Driver.BaseEquity:Year.2026:Scenario.Upside = 6500

# Downside scenario assumptions
